PORT=3001
API_KEY=
KIMI_AUTH=paste_kimi_auth_jwt_here
KIMI_COOKIE=kimi-auth=paste_kimi_auth_jwt_here; __cf_bm=paste_cf_cookie_if_needed
KIMI_STORAGE_STATE=storage/kimi-state.json
KIMI_BASE_URL=https://www.kimi.com
KIMI_CHAT_ENDPOINT=/apiv2/kimi.gateway.chat.v1.ChatService/Chat
KIMI_MODEL=kimi-k2.6
KIMI_SCENARIO=9
KIMI_CONNECT_ENVELOPE=true
KIMI_TYPE_NAME=false
KIMI_USE_EXISTING_CHAT=false
KIMI_CHAT_ID=
KIMI_PARENT_ID=
KIMI_SCENARIO_NAME=SCENARIO_K2D5
KIMI_TOOL_TYPE=TOOL_TYPE_SEARCH
KIMI_ENABLE_SEARCH_WITH_TOOLS=true
KIMI_DEVICE_ID=
KIMI_SESSION_ID=
KIMI_TRAFFIC_ID=
KIMI_REFERER=https://www.kimi.com/
KIMI_REQUEST_TIMEOUT_MS=300000

# Local agent tools. Keep disabled unless you trust the client/user.
AUTO_TOOLS=false
AUTO_TOOLS_AGENT_MODE=pc
AUTO_TOOLS_WORKSPACE=.
AUTO_TOOLS_MAX_STEPS=6
AUTO_TOOLS_FAST_RETURN=true
AUTO_TOOLS_REQUIRE_DIRECTORY_CONFIRM=true
AUTO_TOOLS_ALLOW_COMMANDS=false
